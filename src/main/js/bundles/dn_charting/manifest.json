{
    "name": "dn_charting",
    "version": "1.12.0",
    "title": "${bundleName}",
    "description": "${bundleDescription}",
    "vendor": "con terra GmbH",
    "productName": "devnet-mapapps-charting",
    "i18n": [
        "bundle"
    ],
    "dependencies": {
        "dn_charting-c3": "^0.7.8",
        "@arcgis/core": "^4.33.0",
        "apprt-vue": "^4.20.0",
        "apprt-vuetify": "^4.20.0",
        "apprt-binding": "^4.20.0",
        "apprt-core": "^4.20.0",
        "highlights": "^4.20.0",
        "selection-services": "^4.20.0",
        "result-api": "^4.20.0"
    },
    "cssThemesExtension": [
        {
            "name": "*",
            "files": [
                "./css/styles.css"
            ]
        }
    ],
    "layout-widgets": [
        {
            "widgetRole": "chartingDashboardWidget",
            "sublayout": [
                "desktop",
                "tablet_landscape",
                "tablet_portrait"
            ],
            "window": {
                "dockTool": "chartingDashboardToggleTool",
                "marginBox": {
                    "t": 42,
                    "b": 40,
                    "r": 0,
                    "w": 500
                },
                "fixEdgesInViewPort": {
                    "l": false
                },
                "dockable": true,
                "autofocus": false,
                "minimizeOnClose": true,
                "resizable": true,
                "draggable": false,
                "closable": true,
                "collapsable": true,
                "collapseAxis": {
                    "l": true
                },
                "windowClass": "noPadding"
            }
        },
        {
            "widgetRole": "chartingDashboardWidget",
            "sublayout": [
                "mobile_landscape",
                "mobile_portrait"
            ],
            "window": {
                "autofocus": false,
                "minimizeOnClose": true,
                "marginBox": {
                    "w": "100%",
                    "h": "50%",
                    "b": 40,
                    "l": 0
                },
                "windowClass": "mobileWindow noTitleBarAndWindowTools"
            }
        }
    ],
    "components": [
        {
            "name": "C3ChartsFactory",
            "provides": [
                "dn_charting.C3ChartsFactory"
            ],
            "references": [
                {
                    "name": "c3ChartsDataProvider",
                    "providing": "dn_charting.C3ChartsDataProvider"
                }
            ]
        },
        {
            "name": "C3ChartsDataProvider",
            "provides": [
                "dn_charting.C3ChartsDataProvider"
            ]
        },
        {
            "name": "ChartingDashboardWidgetModel",
            "provides": [
                "dn_charting.ChartingDashboardWidgetModel"
            ],
            "propertiesConstructor": true,
            "properties": {
                "drawTabGeometries": true,
                "drawChartsForSelectionResults": true,
                "relationships": [],
                "chartsProperties": [],
                "chartsTabs": []
            }
        },
        {
            "name": "ChartingDashboardController",
            "provides": [
                "dn_charting.ChartingDashboardController",
                "ct.framework.api.EventHandler"
            ],
            "properties": {
                "Event-Topics": [
                    {
                        "topic": "selection/EXECUTING",
                        "method": "receiveSelections"
                    }
                ]
            },
            "references": [
                {
                    "name": "model",
                    "providing": "dn_charting.ChartingDashboardWidgetModel"
                },
                {
                    "name": "c3ChartsFactory",
                    "providing": "dn_charting.C3ChartsFactory"
                },
                {
                    "name": "queryController",
                    "providing": "dn_charting.QueryController"
                },
                {
                    "name": "highlighter",
                    "providing": "highlights.HighlightService"
                },
                {
                    "name": "tool",
                    "providing": "ct.tools.Tool",
                    "filter": "(id=chartingDashboardToggleTool)"
                }
            ]
        },
        {
            "name": "ChartingDashboardWidgetFactory",
            "provides": [
                "dijit.Widget"
            ],
            "instanceFactory": true,
            "immediate": true,
            "properties": {
                "widgetRole": "chartingDashboardWidget"
            },
            "references": [
                {
                    "name": "chartingDashboardWidgetModel",
                    "providing": "dn_charting.ChartingDashboardWidgetModel"
                },
                {
                    "name": "controller",
                    "providing": "dn_charting.ChartingDashboardController"
                }
            ]
        },
        {
            "name": "ChartingBulkAction",
            "provides": [
                "result-api.BulkTableAction"
            ],
            "propertiesConstructor": true,
            "properties": {
                "icon": "icon-chart-pie",
                "label": "${tool.title}",
                "tooltip": "${tool.tooltip}",
                "priority": 1
            },
            "references": [
                {
                    "name": "controller",
                    "providing": "dn_charting.ChartingDashboardController",
                    "cardinality": "0..1"
                }
            ]
        },
        {
            "name": "ChartingDashboardToggleTool",
            "impl": "ct/tools/Tool",
            "provides": [
                "ct.tools.Tool"
            ],
            "propertiesConstructor": true,
            "properties": {
                "id": "chartingDashboardToggleTool",
                "title": "${tool.title}",
                "tooltip": "${tool.tooltip}",
                "iconClass": "icon-chart-pie",
                "togglable": true,
                "noGroup": true
            }
        },
        {
            "name": "QueryController",
            "provides": "dn_charting.QueryController"
        }
    ]
}
